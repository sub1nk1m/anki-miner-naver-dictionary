{
  "manifest_version": 3,
  "name": "Anki Miner for Naver Dictionary",
  "version": "0.1.2",
  "description": "네이버 사전의 검색 결과를 원클릭으로 Anki 덱에 저장해줍니다.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": [
    "*://*.naver.com/*",
    "*://*.tatoeba.org/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
