{
  "manifest_version": 3,
  "name": "Naver Japanese Dictionary (Anki)",
  "version": "1.0.0",
  "description": "Yomitan-style hover dictionary using Naver Japanese Dictionary with 1-click Anki export.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": [
    "*://*.naver.com/*",
    "*://*.tatoeba.org/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
